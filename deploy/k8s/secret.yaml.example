# Copy to secret.yaml and apply, or create from CLI:
#   oc create secret generic unified-dashboard-secrets \
#     --from-literal=GITHUB_TOKEN=<token> -n unified-dashboard
apiVersion: v1
kind: Secret
metadata:
  name: unified-dashboard-secrets
  labels:
    app.kubernetes.io/name: unified-dashboard
type: Opaque
stringData:
  # Required for stable API usage (5000 core req/hr + 30 search req/min)
  GITHUB_TOKEN: ""
