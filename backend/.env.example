# 1. Run:  cp .env.example .env
# 2. Put your token in .env (NOT in this example file):
#    GITHUB_TOKEN=ghp_xxxxxxxx
# Never commit .env — it is gitignored.
GITHUB_TOKEN=

# Gemini API key for AI mode (issue complexity analysis)
GEMINI_API_KEY=

# Gemini Model for AI mode (issue complexity analysis)
GEMINI_MODEL=

# GitHub organization to list repositories for
GITHUB_ORG=tektoncd

# Server
PORT=8081

# Comma-separated origins allowed for CORS (frontend dev server)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# In-memory API response cache TTL (minutes)
CACHE_TTL_MINUTES=15
